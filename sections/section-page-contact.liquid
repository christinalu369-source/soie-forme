{% comment %}
  Section: Page Contact
  Contact form and store information for Soie & Forme.
  Used in templates/page.contact.json
{% endcomment %}

<div class="contact-page">

  <!-- ── HEADER ── -->
  <div class="contact-header">
    <p class="contact-header__eyebrow">{{ section.settings.eyebrow | default: 'Get in touch' }}</p>
    <h1 class="contact-header__heading">{{ section.settings.heading | default: 'We would love to hear from you.' }}</h1>
    <p class="contact-header__sub">{{ section.settings.subtext | default: 'Whether you have a question about a product, need help with sizing, or are interested in a bespoke order — reach out and we will respond within 1–2 business days.' }}</p>
  </div>

  <!-- ── CONTENT GRID ── -->
  <div class="contact-body">

    <!-- Contact form -->
    <div class="contact-form-wrap">
      {%- form 'contact', id: 'contact-form' -%}

        {%- if form.posted_successfully? -%}
          <div class="contact-success" role="alert">
            <p>Thank you — your message has been received. We will be in touch shortly.</p>
          </div>
        {%- endif -%}

        {%- if form.errors -%}
          <div class="contact-errors" role="alert">
            <p>Please check the following:</p>
            <ul>
              {%- for field in form.errors -%}
                <li>{{ field | capitalize }}: {{ form.errors.messages[field] }}</li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}

        <div class="contact-field">
          <label for="contact-name" class="contact-label">Name</label>
          <input
            type="text"
            id="contact-name"
            name="contact[name]"
            class="contact-input"
            autocomplete="name"
            value="{{ form.value['contact[name]'] }}"
            required
          >
        </div>

        <div class="contact-field">
          <label for="contact-email" class="contact-label">Email</label>
          <input
            type="email"
            id="contact-email"
            name="contact[email]"
            class="contact-input"
            autocomplete="email"
            value="{{ form.value['contact[email]'] }}"
            required
          >
        </div>

        <div class="contact-field">
          <label for="contact-subject" class="contact-label">Subject</label>
          <input
            type="text"
            id="contact-subject"
            name="contact[body][subject]"
            class="contact-input"
            value="{{ form.value['contact[body][subject]'] }}"
          >
        </div>

        <div class="contact-field">
          <label for="contact-message" class="contact-label">Message</label>
          <textarea
            id="contact-message"
            name="contact[body]"
            class="contact-input contact-input--textarea"
            rows="6"
            required
          >{{ form.value['contact[body]'] }}</textarea>
        </div>

        <button type="submit" class="contact-submit">
          <span>Send message</span>
        </button>

      {%- endform -%}
    </div>

    <!-- Aside: info -->
    <aside class="contact-aside">

      <div class="contact-aside__block">
        <div class="contact-aside__label">Email</div>
        <a href="mailto:{{ section.settings.email | default: 'hello@soieandforme.com' }}" class="contact-aside__link">
          {{ section.settings.email | default: 'hello@soieandforme.com' }}
        </a>
      </div>

      <div class="contact-aside__block">
        <div class="contact-aside__label">Response time</div>
        <p class="contact-aside__text">{{ section.settings.response_time | default: 'We respond within 1–2 business days.' }}</p>
      </div>

      <div class="contact-aside__block">
        <div class="contact-aside__label">Bespoke orders</div>
        <p class="contact-aside__text">{{ section.settings.bespoke_note | default: 'For custom sizing, monogramming, or material enquiries, please mention your request in your message.' }}</p>
      </div>

    </aside>

  </div><!-- /contact-body -->

</div><!-- /contact-page -->

{% schema %}
{
  "name": "Contact Page",
  "settings": [
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Get in touch"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "We would love to hear from you."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Whether you have a question about a product, need help with sizing, or are interested in a bespoke order — reach out and we will respond within 1–2 business days."
    },
    {
      "type": "header",
      "content": "Contact Information"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email address",
      "default": "hello@soieandforme.com"
    },
    {
      "type": "text",
      "id": "response_time",
      "label": "Response time note",
      "default": "We respond within 1–2 business days."
    },
    {
      "type": "textarea",
      "id": "bespoke_note",
      "label": "Bespoke orders note",
      "default": "For custom sizing, monogramming, or material enquiries, please mention your request in your message."
    }
  ],
  "presets": [
    {
      "name": "Contact Page"
    }
  ]
}
{% endschema %}
