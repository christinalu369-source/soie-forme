{% comment %}
  Section: List Collections
  Renders a grid of collection cards for the /collections page.
  Each card links to that collection's product grid.
{% endcomment %}

<div class="list-collections-page">

  <header class="collection-header">
    <p class="collection-header__eyebrow">{{ section.settings.eyebrow | default: 'Shop' }}</p>
    <h1 class="collection-header__title">{{ section.settings.heading | default: 'All Collections' }}</h1>
  </header>

  <div class="list-collections-grid">
    {%- for collection in collections -%}
        <a href="{{ collection.url }}" class="collection-card">
          <div class="collection-card__image-wrap">
            {%- if collection.image != blank -%}
              <img
                src="{{ collection.image | image_url: width: 800 }}"
                alt="{{ collection.image.alt | escape | default: collection.title }}"
                loading="lazy"
              >
            {%- elsif collection.products.first.featured_image != blank -%}
              <img
                src="{{ collection.products.first.featured_image | image_url: width: 800 }}"
                alt="{{ collection.title | escape }}"
                loading="lazy"
              >
            {%- else -%}
              <div class="collection-card__placeholder"></div>
            {%- endif -%}
          </div>
          <div class="collection-card__info">
            <h2 class="collection-card__title">{{ collection.title }}</h2>
            <span class="collection-card__count">{{ collection.products_count }} {{ collection.products_count | pluralize: 'product', 'products' }}</span>
          </div>
        </a>
    {%- else -%}
      <p class="list-collections-empty">No collections yet — check back soon.</p>
    {%- endfor -%}
  </div>

</div>

{% schema %}
{
  "name": "Collections List",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Shop"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "All Collections"
    }
  ],
  "presets": [
    {
      "name": "Collections List"
    }
  ]
}
{% endschema %}
