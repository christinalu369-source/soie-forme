{% comment %}
  Section: Page About
  Brand story / editorial page for Soie & Forme.
  Used in templates/page.about.json
{% endcomment %}

<!-- ── ABOUT HERO ── -->
<section class="about-hero">
  <div class="about-hero__inner">
    <p class="about-hero__eyebrow">{{ section.settings.eyebrow | default: 'Our Story' }}</p>
    <h1 class="about-hero__heading">{{ section.settings.heading | default: 'Crafted from silence,<br>shaped by touch.' }}</h1>
  </div>
</section>

<!-- ── ABOUT INTRO ── -->
<section class="about-intro">
  <div class="about-intro__inner">
    <div class="about-intro__text">
      <p>{{ section.settings.intro_text | default: 'Soie & Forme was born from a belief that the fabrics closest to your skin deserve the same quiet attention you bring to everything else. We source only the finest natural fibres — pure silk, linen, cotton — chosen for their hand-feel first and their beauty second.' }}</p>
    </div>

    {%- if section.settings.intro_image != blank -%}
      <div class="about-intro__image">
        <img
          src="{{ section.settings.intro_image | image_url: width: 1200 }}"
          alt="{{ section.settings.intro_image.alt | escape | default: 'Soie & Forme' }}"
          width="{{ section.settings.intro_image.width }}"
          height="{{ section.settings.intro_image.height }}"
          loading="lazy"
        >
      </div>
    {%- else -%}
      <div class="about-intro__image about-intro__image--placeholder"></div>
    {%- endif -%}
  </div>
</section>

<!-- ── ABOUT PHILOSOPHY ── -->
<section class="about-philosophy">
  <div class="about-philosophy__inner">
    <div class="about-philosophy__rule" aria-hidden="true"></div>
    <h2 class="about-philosophy__heading">{{ section.settings.philosophy_heading | default: 'The philosophy' }}</h2>
    <div class="about-philosophy__body">
      <p>{{ section.settings.philosophy_text | default: 'We believe in less, but better. Each piece in our collection is considered from fibre to finish — selected to last seasons, not just seasons of trend. Silk that drapes like water. Linen that softens with each wash. Objects that earn a permanent place in your daily ritual.' }}</p>
    </div>
  </div>
</section>

<!-- ── VALUES STRIP ── -->
<section class="about-values">
  <div class="about-values__inner">

    <div class="about-values__item">
      <div class="about-values__label">Fibre</div>
      <p class="about-values__text">Only natural fibres — silk, linen, and cotton — selected for exceptional hand-feel and longevity.</p>
    </div>

    <div class="about-values__divider" aria-hidden="true"></div>

    <div class="about-values__item">
      <div class="about-values__label">Craft</div>
      <p class="about-values__text">Each piece produced in small runs, allowing for the attention to detail that mass production erases.</p>
    </div>

    <div class="about-values__divider" aria-hidden="true"></div>

    <div class="about-values__item">
      <div class="about-values__label">Ritual</div>
      <p class="about-values__text">Designed to become part of your daily practice — the objects you reach for without thinking.</p>
    </div>

  </div>
</section>

<!-- ── ABOUT CLOSING ── -->
<section class="about-closing">
  <div class="about-closing__inner">
    <p class="about-closing__text">{{ section.settings.closing_text | default: 'Questions about a product, custom sizing, or bespoke orders? We love to hear from you.' }}</p>
    <a href="/pages/contact" class="about-closing__cta">Get in touch</a>
  </div>
</section>

{% schema %}
{
  "name": "About Page",
  "settings": [
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Our Story"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Hero heading",
      "default": "Crafted from silence, shaped by touch."
    },
    {
      "type": "header",
      "content": "Introduction"
    },
    {
      "type": "textarea",
      "id": "intro_text",
      "label": "Introduction paragraph",
      "default": "Soie & Forme was born from a belief that the fabrics closest to your skin deserve the same quiet attention you bring to everything else. We source only the finest natural fibres — pure silk, linen, cotton — chosen for their hand-feel first and their beauty second."
    },
    {
      "type": "image_picker",
      "id": "intro_image",
      "label": "Introduction image"
    },
    {
      "type": "header",
      "content": "Philosophy"
    },
    {
      "type": "text",
      "id": "philosophy_heading",
      "label": "Philosophy heading",
      "default": "The philosophy"
    },
    {
      "type": "textarea",
      "id": "philosophy_text",
      "label": "Philosophy paragraph",
      "default": "We believe in less, but better. Each piece in our collection is considered from fibre to finish — selected to last seasons, not just seasons of trend."
    },
    {
      "type": "header",
      "content": "Closing"
    },
    {
      "type": "textarea",
      "id": "closing_text",
      "label": "Closing text",
      "default": "Questions about a product, custom sizing, or bespoke orders? We love to hear from you."
    }
  ],
  "presets": [
    {
      "name": "About Page"
    }
  ]
}
{% endschema %}
