<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#FAF8F3">

  <title>{{ page_title }} — Soie &amp; Forme</title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}

  <!-- Open Graph -->
  <meta property="og:site_name" content="{{ shop.name }}">
  <meta property="og:title" content="{{ page_title }}">
  {%- if page_description -%}
    <meta property="og:description" content="{{ page_description | escape }}">
  {%- endif -%}
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ canonical_url }}">

  <!-- Canonical -->
  <link rel="canonical" href="{{ canonical_url }}">

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@400;500;600;700;800&family=DM+Mono:ital,wght@0,300;0,400;1,300&display=swap" rel="stylesheet">

  <!-- Styles -->
  {{ 'base.css' | asset_url | stylesheet_tag }}
  {{ 'component-product-card.css' | asset_url | stylesheet_tag }}
  {{ 'section-collection.css' | asset_url | stylesheet_tag }}
  {{ 'section-product-main.css' | asset_url | stylesheet_tag }}
  {{ 'global-nav.css' | asset_url | stylesheet_tag }}
  {{ 'section-page-about.css' | asset_url | stylesheet_tag }}
  {{ 'section-page-contact.css' | asset_url | stylesheet_tag }}

  {{ content_for_header }}
</head>

<body>
  <!-- Custom cursor -->
  <div class="cursor" id="cursor" aria-hidden="true"></div>
  <div class="cursor-ring" id="cursor-ring" aria-hidden="true"></div>

  <!-- Navigation -->
  <nav id="site-nav" role="navigation" aria-label="Main navigation">
    <a href="{{ routes.root_url }}" class="nav-logo">
      Soie <span class="nav-logo__amp">&amp;</span> Forme
    </a>

    <ul class="nav-links" role="list">
      <li><a href="{{ routes.collections_url }}">Collections</a></li>
      <li><a href="/pages/about">About</a></li>
      <li><a href="/pages/contact">Contact</a></li>
    </ul>

    <div class="nav-actions">
      <a href="{{ routes.search_url }}" aria-label="Search">Search</a>
      <a href="{{ routes.cart_url }}" class="nav-cart" aria-label="Cart ({{ cart.item_count }} items)">
        {%- if cart.item_count > 0 -%}
          <span class="nav-cart__count">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>
    </div>
  </nav>

  <main id="main-content">
    {{ content_for_layout }}
  </main>

  <!-- Footer -->
  <footer role="contentinfo">
    <div class="footer-inner">
      <div class="footer-brand">
        <div class="footer-logo">Soie <span class="footer-logo__amp">&amp;</span> Forme</div>
        <p class="footer-tagline">Quietly refined silk essentials<br>for your everyday rituals.</p>
        <div class="footer-social">
          <a href="#">Instagram</a>
          <a href="#">Pinterest</a>
        </div>
      </div>

      <div class="footer-col">
        <div class="footer-col__title">Shop</div>
        <ul role="list">
          <li><a href="{{ routes.collections_url }}">All Collections</a></li>
          <li><a href="/collections/silk">Silk</a></li>
          <li><a href="/collections/linen">Linen</a></li>
          <li><a href="/collections/new-arrivals">New Arrivals</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <div class="footer-col__title">Information</div>
        <ul role="list">
          <li><a href="/pages/about">Our Story</a></li>
          <li><a href="/pages/materials">Materials</a></li>
          <li><a href="/pages/bespoke">Bespoke</a></li>
          <li><a href="/pages/care-guide">Care Guide</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <div class="footer-col__title">Support</div>
        <ul role="list">
          <li><a href="/pages/contact">Contact</a></li>
          <li><a href="/pages/shipping">Shipping</a></li>
          <li><a href="/pages/returns">Returns</a></li>
          <li><a href="/pages/faq">FAQ</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <span class="footer-copy">&copy; {{ 'now' | date: '%Y' }} Soie &amp; Forme. All rights reserved.</span>
    </div>
  </footer>

  <script src="{{ 'global.js' | asset_url }}" defer></script>
  <script src="{{ 'section-product-main.js' | asset_url }}" defer></script>
</body>
</html>
